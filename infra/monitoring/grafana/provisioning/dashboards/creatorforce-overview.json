{
  "schemaVersion": 38,
  "uid": "cf-overview",
  "title": "CreatorForce Overview",
  "description": "HTTP traffic, errors, latency, BullMQ jobs, AI cost and token usage, cache hits.",
  "tags": ["creatorforce"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate by Route (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(cf_http_requests_total[2m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate % (5xx / total)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum(rate(cf_http_requests_total{status=~\"5..\"}[2m])) / sum(rate(cf_http_requests_total[2m]))",
          "legendFormat": "5xx error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 Request Latency (seconds)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cf_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cf_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Jobs Completed / Failed (per minute)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (type) (rate(cf_jobs_total{status=\"completed\"}[2m])) * 60",
          "legendFormat": "completed – {{type}}",
          "refId": "A"
        },
        {
          "expr": "sum by (type) (rate(cf_jobs_total{status=\"failed\"}[2m])) * 60",
          "legendFormat": "FAILED – {{type}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "FAILED.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "AI Cost USD / Hour",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(cf_ai_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI Tokens / Second by Provider",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (provider, direction) (rate(cf_ai_tokens_total[2m]))",
          "legendFormat": "{{provider}} – {{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache Hits / Second by Kind",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (kind) (rate(cf_ai_cache_hits_total[2m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1 }
        }
      }
    }
  ]
}
