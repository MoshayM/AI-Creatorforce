{
  "name": "creatorforce-ai",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @cf/db migrate:dev",
    "db:push": "pnpm --filter @cf/db db:push",
    "db:seed": "pnpm --filter @cf/db db:seed",
    "db:studio": "pnpm --filter @cf/db studio",
    "changelog": "node scripts/generate-changelog.mjs",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
