// This file is kept in sync with ../../infra/db/schema.prisma
// Copy from infra/db/schema.prisma — Prisma requires schema to be in /prisma by default

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  emailVerified DateTime?
  role          UserRole  @default(OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels      Channel[]
  projects      Project[]
  apiKeys       ApiKey[]
  subscription  Subscription?
  usageLogs     UsageLog[]

  @@map("users")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ── YouTube Channels ──────────────────────────────────────────────────────────

model Channel {
  id               String    @id @default(cuid())
  userId           String
  youtubeChannelId String    @unique
  title            String
  description      String?
  thumbnailUrl     String?
  customUrl        String?
  subscriberCount  Int       @default(0)
  videoCount       Int       @default(0)
  encryptedTokens  String?
  tokenExpiresAt   DateTime?
  scopes           String[]  @default([])
  readOnly         Boolean   @default(false)
  active           Boolean   @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  niche            String?
  voiceProfile     Json?
  brandKit         Json?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects           Project[]
  videos             Video[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@map("channels")
}

// ── Projects ──────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  channelId   String
  title       String
  description String?
  status      ProjectStatus @default(DRAFT)
  niche       String?
  targetLang  String        @default("en")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel        Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  jobs           AgentJob[]
  videos         Video[]
  approvals      Approval[]
  assets         Asset[]
  timelines      Timeline[]
  renders        Render[]
  importedVideos ImportedVideo[]
  shortClips     ShortClip[]

  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// ── Agent Jobs ────────────────────────────────────────────────────────────────

model AgentJob {
  id          String    @id @default(cuid())
  projectId   String
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json      @default("{}")
  result      Json?
  error       String?
  attempts    Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentLogs AgentLog[]
  approval  Approval?

  @@map("agent_jobs")
}

enum JobType {
  RESEARCH
  SCRIPT
  FACT_CHECK
  COMPLIANCE
  METADATA
  THUMBNAIL
  TREND_ANALYSIS
  SEO_OPTIMIZATION
  AUDIENCE_ANALYSIS
  PUBLISH
  // Beta: media pipeline & editor
  VOICE_SPEC
  VOICE_GENERATE
  IMAGE_BRIEF
  IMAGE_GENERATE
  MUSIC_BRIEF
  MUSIC_GENERATE
  VIDEO_SCENE_PLAN
  VIDEO_GENERATE
  SUBTITLE_GENERATE
  EDIT_PLAN
  RENDER
  FULL_PRODUCTION
  ANALYTICS
  GROWTH_REPORT
  // Shorts Studio (ai.md spec, Section 15)
  SHORTS_ANALYZE
  VIDEO_IMPORT
  TRANSCRIPT_ANALYSIS
  SCENE_DETECTION
  TOPIC_SEGMENTATION
  HIGHLIGHT_DETECTION
  SHORTS_GENERATION
  AUTO_EDIT
  CAPTION_GENERATION
  SHORTS_RENDER
  SHORTS_EXPORT
  SHORTS_PUBLISH
  // Video Intelligence (Ai-video edit.md §5, Phase 5)
  CHAPTER_DETECTION
  EMBEDDING_GENERATION
  CHURCH_PACK_GENERATION
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  WAITING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
  FAILED
  CANCELLED
}

// ── Agent Logs ────────────────────────────────────────────────────────────────

model AgentLog {
  id        String   @id @default(cuid())
  jobId     String
  agentName String
  step      String
  input     Json?
  output    Json?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  latencyMs Int      @default(0)
  createdAt DateTime @default(now())

  job AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

// ── Compliance ────────────────────────────────────────────────────────────────

model ComplianceResult {
  id         String           @id @default(cuid())
  jobId      String           @unique
  passed     Boolean
  score      Float
  flags      ComplianceFlag[]
  reviewedAt DateTime         @default(now())
  reviewerAI String

  @@map("compliance_results")
}

model ComplianceFlag {
  id                 String           @id @default(cuid())
  complianceResultId String
  category           String
  severity           FlagSeverity
  description        String
  excerpt            String?

  result ComplianceResult @relation(fields: [complianceResultId], references: [id], onDelete: Cascade)

  @@map("compliance_flags")
}

enum FlagSeverity {
  INFO
  WARNING
  CRITICAL
  BLOCK
}

// ── Approvals ─────────────────────────────────────────────────────────────────

model Approval {
  id         String         @id @default(cuid())
  projectId  String
  jobId      String         @unique
  status     ApprovalStatus @default(PENDING)
  reviewedBy String?
  notes      String?
  reviewedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime       @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job     AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ── Videos ────────────────────────────────────────────────────────────────────

model Video {
  id             String      @id @default(cuid())
  projectId      String
  channelId      String
  youtubeVideoId String?     @unique
  title          String
  description    String?
  tags           String[]    @default([])
  thumbnailUrl   String?
  status         VideoStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  viewCount      Int         @default(0)
  likeCount      Int         @default(0)
  commentCount   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  channel Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  scripts Script[]

  @@map("videos")
}

enum VideoStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

// ── Scripts ───────────────────────────────────────────────────────────────────

model Script {
  id        String   @id @default(cuid())
  videoId   String
  version   Int      @default(1)
  content   String
  wordCount Int      @default(0)
  sources   Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("scripts")
}

// ── Billing ───────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model UsageLog {
  id        String    @id @default(cuid())
  userId    String
  resource  UsageType
  quantity  Int       @default(1)
  meta      Json      @default("{}")
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_logs")
}

enum UsageType {
  AI_TOKENS
  VIDEO_GENERATED
  VIDEO_PUBLISHED
  RESEARCH_QUERY
  COMPLIANCE_CHECK
  VOICE_SECONDS
  IMAGE_GENERATED
  MUSIC_GENERATED
  VIDEO_CLIP_GENERATED
  RENDER_MINUTES
}

// ── Media Assets ──────────────────────────────────────────────────────────────

enum AssetKind {
  MUSIC
  VIDEO
  THUMBNAIL
  VOICE
  IMAGE
  SUBTITLE
  RENDER_SOURCE
  UPLOAD
  // Shorts Studio (ai.md spec, Section 14)
  SHORTS_SOURCE_VIDEO
  SHORTS_TRANSCRIPT
  SHORTS_SCENE_MANIFEST
  SHORTS_CLIP_RENDER
  SHORTS_CAPTION_TRACK
  SHORTS_MUSIC
  SHORTS_SFX
  SHORTS_VOICE
  SHORTS_THUMBNAIL
  SHORTS_PREVIEW
  SHORTS_FINAL_EXPORT
}

enum AssetStatus {
  BRIEFED
  GENERATING
  READY
  FAILED
  ACCEPTED
}

model Asset {
  id               String      @id @default(cuid())
  projectId        String
  kind             AssetKind
  currentVersionId String?
  status           AssetStatus @default(BRIEFED)
  label            String?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions AssetVersion[]

  importedVideoSources ImportedVideo[]
  shortClipRenders     ShortClip[]
  shortsTimelineItems  ShortsTimelineItem[]
  shortsThumbnails     ShortsThumbnail[]
  shortsExports        ShortsExportHistory[]

  @@index([projectId, kind, status])
  @@map("assets")
}

model AssetVersion {
  id             String   @id @default(cuid())
  assetId        String
  version        Int
  r2Key          String?
  contentHash    String?
  provider       String?
  model          String?
  prompt         Json?
  params         Json?
  provenance     Json?
  sizeBytes      BigInt   @default(0)
  durationMs     Int?
  wordTimestamps Json?
  createdAt      DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@index([contentHash])
  @@map("asset_versions")
}

// ── Timeline & Render ─────────────────────────────────────────────────────────

model Timeline {
  id          String   @id @default(cuid())
  projectId   String
  version     Int      @default(1)
  label       String?
  fps         Int      @default(30)
  resolution  Json     @default("{\"width\":1920,\"height\":1080}")
  tracks      Json     @default("{\"schemaVersion\":1,\"tracks\":[]}")
  contentHash String?
  isDraft     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renders Render[]

  @@index([projectId, version])
  @@map("timelines")
}

enum RenderPreset {
  DRAFT_PROXY
  YT_1080P
  YT_4K
  SHORTS_1080X1920
}

enum RenderStatus {
  QUEUED
  RENDERING
  READY
  FAILED
}

model Render {
  id              String       @id @default(cuid())
  projectId       String
  timelineId      String
  timelineVersion Int
  preset          RenderPreset
  status          RenderStatus @default(QUEUED)
  progressPct     Int          @default(0)
  r2Key           String?
  sizeBytes       BigInt?
  durationMs      Int?
  checksum        String?
  costCredits     Decimal      @default(0) @db.Decimal(10, 4)
  error           Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeline Timeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@unique([projectId, timelineVersion, preset])
  @@map("renders")
}

// ── Analytics ─────────────────────────────────────────────────────────────────

model AnalyticsSnapshot {
  id         String   @id @default(cuid())
  channelId  String
  ytVideoId  String?
  capturedAt DateTime @default(now())
  metrics    Json

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, ytVideoId, capturedAt])
  @@map("analytics_snapshots")
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ── Prompt Versions ───────────────────────────────────────────────────────────

model PromptVersion {
  id        String   @id @default(cuid())
  key       String
  version   Int
  body      String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([key, version])
  @@index([key, active])
  @@map("prompt_versions")
}

// ── Teams (Beta) ──────────────────────────────────────────────────────────────

model Team {
  id        String         @id @default(cuid())
  name      String
  ownerId   String
  planTier  String         @default("free")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  memberships TeamMembership[]

  @@map("teams")
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  REVIEWER
  VIEWER
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(VIEWER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_memberships")
}

// ── Shorts Studio (ai.md spec, Section 17) ────────────────────────────────────
// New relational timeline models are prefixed "Shorts" to avoid colliding with
// the existing project-level Timeline (Json tracks) used by the long-form editor.

model ImportedVideo {
  id               String           @id @default(cuid())
  projectId        String
  youtubeVideoId   String
  title            String
  description      String?          @db.Text
  durationMs       Int
  thumbnailUrl     String?
  viewCount        BigInt?
  likeCount        BigInt?
  commentCount     BigInt?
  sourceAssetId    String?
  transcriptStatus TranscriptStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceAsset Asset?  @relation(fields: [sourceAssetId], references: [id])

  transcriptSegments TranscriptSegment[]
  scenes             VideoScene[]
  topicSegments      TopicSegment[]
  chapters           Chapter[]

  @@unique([projectId, youtubeVideoId])
  @@index([projectId])
  @@map("imported_videos")
}

// ── Chapters (Ai-video edit.md §5/§11, Phase 5) ────────────────────────────────
// YouTube-style chapters derived from the topic-segment analysis graph — one
// contiguous partition of the video. `source` distinguishes AI-detected rows
// from chapters imported from YouTube (Phase 6 sync); user edits are flagged so
// re-detection never overwrites a manual rename.

enum ChapterSource {
  DETECTED
  IMPORTED
}

model Chapter {
  id              String        @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  title           String
  summary         String        @db.Text
  keyPoints       String[]      @default([])
  confidence      Float
  source          ChapterSource @default(DETECTED)
  editedByUser    Boolean       @default(false)
  // Church AI pack (Ai-video edit.md §11) — filled by CHURCH_PACK_GENERATION,
  // empty until the pack is requested. devotional set == chapter processed.
  bibleRefs           String[] @default([])
  discussionQuestions String[] @default([])
  devotional          String?  @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)
  clips         ShortClip[]

  @@index([importedVideoId, startMs])
  @@map("chapters")
}

enum TranscriptStatus {
  PENDING
  YOUTUBE_CAPTIONS
  ASR_GENERATED
  FAILED
}

model TranscriptSegment {
  id              String   @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  speakerId       String?
  text            String   @db.Text
  embedding       Float[]  @default([])
  createdAt       DateTime @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)

  @@index([importedVideoId, startMs])
  @@map("transcript_segments")
}

model VideoScene {
  id                    String   @id @default(cuid())
  importedVideoId       String
  startMs               Int
  endMs                 Int
  speakerId             String?
  emotionScores         Json?
  sceneChangeConfidence Float?
  createdAt             DateTime @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)

  @@index([importedVideoId, startMs])
  @@map("video_scenes")
}

model TopicSegment {
  id              String        @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  category        TopicCategory
  title           String
  summary         String        @db.Text
  confidence      Float
  createdAt       DateTime      @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)
  highlight     Highlight?
  clips         ShortClip[]

  @@index([importedVideoId, startMs])
  @@map("topic_segments")
}

enum TopicCategory {
  QUESTION_ANSWERED
  STORY
  TUTORIAL_STEP
  FUNNY_MOMENT
  IMPORTANT_STATEMENT
  HOOK
  PROBLEM
  SOLUTION
  STATISTIC
  TIP
  MISTAKE
  WARNING
  QUOTE
  OPINION
  LESSON
  SUCCESS_STORY
  FAILURE
  CALL_TO_ACTION
}

model Highlight {
  id               String   @id @default(cuid())
  topicSegmentId   String   @unique
  virality         Float
  emotion          Float
  retention        Float
  hookStrength     Float
  education        Float
  entertainment    Float
  confidence       Float
  trendPotential   Float
  shortSuitability Float
  finalScore       Float
  reason           String   @db.Text
  titleSuggestion  String
  keywords         String[] @default([])
  createdAt        DateTime @default(now())

  topicSegment TopicSegment @relation(fields: [topicSegmentId], references: [id], onDelete: Cascade)

  @@index([finalScore])
  @@map("highlights")
}

model ShortClip {
  id               String          @id @default(cuid())
  // Provenance: exactly one of topicSegmentId (highlight-based Shorts) or
  // chapterId (chapter-based Small Videos, Ai-video edit.md §10) is set.
  topicSegmentId   String?
  chapterId        String?
  projectId        String
  clipType         ClipType
  status           ShortClipStatus @default(CANDIDATE)
  sourceStartMs    Int
  sourceEndMs      Int
  reframeKeyframes Json?
  renderAssetId    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  topicSegment TopicSegment? @relation(fields: [topicSegmentId], references: [id], onDelete: Cascade)
  chapter      Chapter?      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renderAsset  Asset?        @relation(fields: [renderAssetId], references: [id])

  timeline   ShortsTimeline?
  thumbnails ShortsThumbnail[]
  renderJobs ShortsRenderJob[]
  exports    ShortsExportHistory[]

  @@index([projectId, status])
  @@map("short_clips")
}

enum ClipType {
  YOUTUBE_SHORTS
  INSTAGRAM_REELS
  TIKTOK
  LINKEDIN_CLIPS
  FACEBOOK_REELS
  PODCAST_HIGHLIGHTS
  // Horizontal 1–10 min chapter videos (Ai-video edit.md §10, Phase 5)
  SMALL_VIDEO
}

enum ShortClipStatus {
  CANDIDATE
  IN_EDITING
  READY_FOR_RENDER
  RENDERING
  RENDERED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPORTED
  PUBLISHED
}

model ShortsTimeline {
  id          String   @id @default(cuid())
  shortClipId String   @unique
  durationMs  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shortClip   ShortClip             @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  tracks      ShortsTimelineTrack[]
  captions    ShortsCaption[]
  editHistory ShortsTimelineEdit[]

  @@map("shorts_timelines")
}

model ShortsTimelineTrack {
  id         String          @id @default(cuid())
  timelineId String
  type       ShortsTrackType
  orderIndex Int

  timeline ShortsTimeline       @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  items    ShortsTimelineItem[]

  @@index([timelineId, orderIndex])
  @@map("shorts_timeline_tracks")
}

enum ShortsTrackType {
  VIDEO
  AUDIO
  MUSIC
  CAPTION
  OVERLAY
}

model ShortsTimelineItem {
  id            String  @id @default(cuid())
  trackId       String
  startMs       Int
  endMs         Int
  sourceAssetId String?
  cropRect      Json?
  rotationDeg   Float?  @default(0)
  speed         Float?  @default(1.0)
  volume        Float?  @default(1.0)
  properties    Json?

  track       ShortsTimelineTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  sourceAsset Asset?              @relation(fields: [sourceAssetId], references: [id])

  @@index([trackId, startMs])
  @@map("shorts_timeline_items")
}

model ShortsCaption {
  id           String  @id @default(cuid())
  timelineId   String
  startMs      Int
  endMs        Int
  text         String
  speakerColor String?
  emphasis     Boolean @default(false)
  emoji        String?
  templateId   String?

  timeline ShortsTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId, startMs])
  @@map("shorts_captions")
}

model ShortsTimelineEdit {
  id         String   @id @default(cuid())
  timelineId String
  actorId    String // User.id, or 'AI_ASSISTANT'
  command    Json
  createdAt  DateTime @default(now())

  timeline ShortsTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId, createdAt])
  @@map("shorts_timeline_edits")
}

model ShortsThumbnail {
  id          String   @id @default(cuid())
  shortClipId String
  assetId     String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  shortClip ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([shortClipId])
  @@map("shorts_thumbnails")
}

model ShortsRenderJob {
  id             String            @id @default(cuid())
  shortClipId    String
  jobId          String // AgentJob.id
  ffmpegPass     Int               @default(0)
  checkpointData Json?
  status         ShortsRenderStatus @default(QUEUED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  shortClip ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)

  @@index([shortClipId])
  @@map("shorts_render_jobs")
}

enum ShortsRenderStatus {
  QUEUED
  RUNNING
  CHECKPOINTED
  COMPLETE
  FAILED
}

model ShortsExportHistory {
  id              String    @id @default(cuid())
  shortClipId     String
  clipType        ClipType
  exportAssetId   String
  publishedAt     DateTime?
  publishTargetId String?
  createdAt       DateTime  @default(now())

  shortClip   ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  exportAsset Asset     @relation(fields: [exportAssetId], references: [id])

  @@index([shortClipId])
  @@map("shorts_export_history")
}


// ── Unified Intent/Action Layer (Ai-video edit.md §8, §14) ─────────────────────
// One audit trail for every action regardless of input modality (UI click,
// Copilot chat, voice command) — the doc's single-execution-path principle.

enum ActionSource {
  UI
  COPILOT
  VOICE
}

enum ActionStatus {
  EXECUTED
  NEEDS_CONFIRMATION
  FAILED
}

model ActionRecord {
  id            String       @id @default(cuid())
  userId        String
  projectId     String?
  source        ActionSource
  intentType    String
  intentPayload Json         @default("{}")
  status        ActionStatus
  fromCache     Boolean      @default(false)
  tokensUsed    Int          @default(0)
  error         String?
  createdAt     DateTime     @default(now())

  tokenUsage TokenUsage[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("actions")
}

// Compressed conversation memory — intent history + short summary, never raw
// transcripts (token rule §12.2.6). One row per user for now.
model CopilotSessionMemory {
  id            String   @id @default(cuid())
  userId        String   @unique
  summary       String   @default("")
  lastIntentIds String[] @default([])
  updatedAt     DateTime @updatedAt

  @@map("copilot_sessions")
}

// Spoken-command history — powers the transcript chips and future undo (§14).
model VoiceCommand {
  id             String   @id @default(cuid())
  userId         String
  projectId      String?
  rawTranscript  String
  resolvedIntent Json?
  executed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@map("voice_commands")
}

// Token usage ledger — feeds the Analytics AI-usage dashboard (§12.2.8).
model TokenUsage {
  id        String        @id @default(cuid())
  userId    String?
  actionId  String?
  provider  String
  model     String
  tokensIn  Int           @default(0)
  tokensOut Int           @default(0)
  costUsd   Float         @default(0)
  fromCache Boolean       @default(false)
  createdAt DateTime      @default(now())

  action ActionRecord? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("token_usage")
}
