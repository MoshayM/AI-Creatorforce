// This file is kept in sync with ../../infra/db/schema.prisma
// Copy from infra/db/schema.prisma — Prisma requires schema to be in /prisma by default

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

enum UserRole {
  // Elevated roles resolve from SUPER_ADMIN_EMAILS / OWNER_EMAILS env config
  // at login — never hardcoded in source (billing spec §9.2).
  SUPER_ADMIN
  OWNER
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  emailVerified DateTime?
  role          UserRole  @default(OWNER)
  /** §7: set by dispute webhooks — blocks new recharges pending fraud review. */
  rechargesFrozen Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channels      Channel[]
  projects      Project[]
  apiKeys       ApiKey[]
  subscription  Subscription?
  usageLogs     UsageLog[]
  wallet        Wallet?
  payments      Payment[]
  trialGrant    TrialGrant?
  accountLinks  AccountLink[]
  authSessions  AuthSession[]

  @@map("users")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ── YouTube Channels ──────────────────────────────────────────────────────────

model Channel {
  id               String    @id @default(cuid())
  userId           String
  youtubeChannelId String    @unique
  title            String
  description      String?
  thumbnailUrl     String?
  customUrl        String?
  subscriberCount  Int       @default(0)
  videoCount       Int       @default(0)
  encryptedTokens  String?
  tokenExpiresAt   DateTime?
  scopes           String[]  @default([])
  readOnly         Boolean   @default(false)
  active           Boolean   @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  niche            String?
  voiceProfile     Json?
  brandKit         Json?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects           Project[]
  videos             Video[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@map("channels")
}

// ── Projects ──────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  channelId   String
  title       String
  description String?
  status      ProjectStatus @default(DRAFT)
  niche       String?
  targetLang  String        @default("en")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel        Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  jobs           AgentJob[]
  videos         Video[]
  approvals      Approval[]
  assets         Asset[]
  timelines      Timeline[]
  renders        Render[]
  importedVideos ImportedVideo[]
  shortClips     ShortClip[]

  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// ── Agent Jobs ────────────────────────────────────────────────────────────────

model AgentJob {
  id          String    @id @default(cuid())
  projectId   String
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json      @default("{}")
  result      Json?
  error       String?
  attempts    Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentLogs AgentLog[]
  approval  Approval?

  @@map("agent_jobs")
}

enum JobType {
  RESEARCH
  SCRIPT
  FACT_CHECK
  COMPLIANCE
  METADATA
  THUMBNAIL
  TREND_ANALYSIS
  SEO_OPTIMIZATION
  AUDIENCE_ANALYSIS
  PUBLISH
  // Beta: media pipeline & editor
  VOICE_SPEC
  VOICE_GENERATE
  IMAGE_BRIEF
  IMAGE_GENERATE
  MUSIC_BRIEF
  MUSIC_GENERATE
  VIDEO_SCENE_PLAN
  VIDEO_GENERATE
  SUBTITLE_GENERATE
  EDIT_PLAN
  RENDER
  FULL_PRODUCTION
  ANALYTICS
  GROWTH_REPORT
  // Shorts Studio (ai.md spec, Section 15)
  SHORTS_ANALYZE
  VIDEO_IMPORT
  TRANSCRIPT_ANALYSIS
  SCENE_DETECTION
  TOPIC_SEGMENTATION
  HIGHLIGHT_DETECTION
  SHORTS_GENERATION
  AUTO_EDIT
  CAPTION_GENERATION
  SHORTS_RENDER
  SHORTS_EXPORT
  SHORTS_PUBLISH
  // Video Intelligence (Ai-video edit.md §5, Phase 5)
  CHAPTER_DETECTION
  EMBEDDING_GENERATION
  CHURCH_PACK_GENERATION
  SOCIAL_CONTENT_GENERATION
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  WAITING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
  FAILED
  CANCELLED
}

// ── Agent Logs ────────────────────────────────────────────────────────────────

model AgentLog {
  id        String   @id @default(cuid())
  jobId     String
  agentName String
  step      String
  input     Json?
  output    Json?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  latencyMs Int      @default(0)
  createdAt DateTime @default(now())

  job AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

// ── Compliance ────────────────────────────────────────────────────────────────

model ComplianceResult {
  id         String           @id @default(cuid())
  jobId      String           @unique
  passed     Boolean
  score      Float
  flags      ComplianceFlag[]
  reviewedAt DateTime         @default(now())
  reviewerAI String

  @@map("compliance_results")
}

model ComplianceFlag {
  id                 String           @id @default(cuid())
  complianceResultId String
  category           String
  severity           FlagSeverity
  description        String
  excerpt            String?

  result ComplianceResult @relation(fields: [complianceResultId], references: [id], onDelete: Cascade)

  @@map("compliance_flags")
}

enum FlagSeverity {
  INFO
  WARNING
  CRITICAL
  BLOCK
}

// ── Approvals ─────────────────────────────────────────────────────────────────

model Approval {
  id         String         @id @default(cuid())
  projectId  String
  jobId      String         @unique
  status     ApprovalStatus @default(PENDING)
  reviewedBy String?
  notes      String?
  reviewedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime       @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job     AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ── Videos ────────────────────────────────────────────────────────────────────

model Video {
  id             String      @id @default(cuid())
  projectId      String
  channelId      String
  youtubeVideoId String?     @unique
  title          String
  description    String?
  tags           String[]    @default([])
  thumbnailUrl   String?
  status         VideoStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  viewCount      Int         @default(0)
  likeCount      Int         @default(0)
  commentCount   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  channel Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  scripts Script[]

  @@map("videos")
}

enum VideoStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

// ── Scripts ───────────────────────────────────────────────────────────────────

model Script {
  id        String   @id @default(cuid())
  videoId   String
  version   Int      @default(1)
  content   String
  wordCount Int      @default(0)
  sources   Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("scripts")
}

// ── Billing ───────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model UsageLog {
  id        String    @id @default(cuid())
  userId    String
  resource  UsageType
  quantity  Int       @default(1)
  meta      Json      @default("{}")
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_logs")
}

enum UsageType {
  AI_TOKENS
  VIDEO_GENERATED
  VIDEO_PUBLISHED
  RESEARCH_QUERY
  COMPLIANCE_CHECK
  VOICE_SECONDS
  IMAGE_GENERATED
  MUSIC_GENERATED
  VIDEO_CLIP_GENERATED
  RENDER_MINUTES
}

// ── Media Assets ──────────────────────────────────────────────────────────────

enum AssetKind {
  MUSIC
  VIDEO
  THUMBNAIL
  VOICE
  IMAGE
  SUBTITLE
  RENDER_SOURCE
  UPLOAD
  // Shorts Studio (ai.md spec, Section 14)
  SHORTS_SOURCE_VIDEO
  SHORTS_TRANSCRIPT
  SHORTS_SCENE_MANIFEST
  SHORTS_CLIP_RENDER
  SHORTS_CAPTION_TRACK
  SHORTS_MUSIC
  SHORTS_SFX
  SHORTS_VOICE
  SHORTS_THUMBNAIL
  SHORTS_PREVIEW
  SHORTS_FINAL_EXPORT
}

enum AssetStatus {
  BRIEFED
  GENERATING
  READY
  FAILED
  ACCEPTED
}

model Asset {
  id               String      @id @default(cuid())
  projectId        String
  kind             AssetKind
  currentVersionId String?
  status           AssetStatus @default(BRIEFED)
  label            String?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions AssetVersion[]

  importedVideoSources ImportedVideo[]
  shortClipRenders     ShortClip[]
  shortsTimelineItems  ShortsTimelineItem[]
  shortsThumbnails     ShortsThumbnail[]
  shortsExports        ShortsExportHistory[]

  @@index([projectId, kind, status])
  @@map("assets")
}

model AssetVersion {
  id             String   @id @default(cuid())
  assetId        String
  version        Int
  r2Key          String?
  contentHash    String?
  provider       String?
  model          String?
  prompt         Json?
  params         Json?
  provenance     Json?
  sizeBytes      BigInt   @default(0)
  durationMs     Int?
  wordTimestamps Json?
  createdAt      DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@index([contentHash])
  @@map("asset_versions")
}

// ── Timeline & Render ─────────────────────────────────────────────────────────

model Timeline {
  id          String   @id @default(cuid())
  projectId   String
  version     Int      @default(1)
  label       String?
  fps         Int      @default(30)
  resolution  Json     @default("{\"width\":1920,\"height\":1080}")
  tracks      Json     @default("{\"schemaVersion\":1,\"tracks\":[]}")
  contentHash String?
  isDraft     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renders Render[]

  @@index([projectId, version])
  @@map("timelines")
}

enum RenderPreset {
  DRAFT_PROXY
  YT_1080P
  YT_4K
  SHORTS_1080X1920
}

enum RenderStatus {
  QUEUED
  RENDERING
  READY
  FAILED
}

model Render {
  id              String       @id @default(cuid())
  projectId       String
  timelineId      String
  timelineVersion Int
  preset          RenderPreset
  status          RenderStatus @default(QUEUED)
  progressPct     Int          @default(0)
  r2Key           String?
  sizeBytes       BigInt?
  durationMs      Int?
  checksum        String?
  costCredits     Decimal      @default(0) @db.Decimal(10, 4)
  error           Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeline Timeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@unique([projectId, timelineVersion, preset])
  @@map("renders")
}

// ── Analytics ─────────────────────────────────────────────────────────────────

model AnalyticsSnapshot {
  id         String   @id @default(cuid())
  channelId  String
  ytVideoId  String?
  capturedAt DateTime @default(now())
  metrics    Json

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, ytVideoId, capturedAt])
  @@map("analytics_snapshots")
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ── Prompt Versions ───────────────────────────────────────────────────────────

model PromptVersion {
  id        String   @id @default(cuid())
  key       String
  version   Int
  body      String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([key, version])
  @@index([key, active])
  @@map("prompt_versions")
}

// ── Teams (Beta) ──────────────────────────────────────────────────────────────

model Team {
  id        String         @id @default(cuid())
  name      String
  ownerId   String
  planTier  String         @default("free")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  memberships TeamMembership[]

  @@map("teams")
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  REVIEWER
  VIEWER
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(VIEWER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_memberships")
}

// ── Shorts Studio (ai.md spec, Section 17) ────────────────────────────────────
// New relational timeline models are prefixed "Shorts" to avoid colliding with
// the existing project-level Timeline (Json tracks) used by the long-form editor.

model ImportedVideo {
  id               String           @id @default(cuid())
  projectId        String
  youtubeVideoId   String
  title            String
  description      String?          @db.Text
  durationMs       Int
  thumbnailUrl     String?
  viewCount        BigInt?
  likeCount        BigInt?
  commentCount     BigInt?
  sourceAssetId    String?
  transcriptStatus TranscriptStatus @default(PENDING)
  /** Last time the chapter block was published into the YouTube description (§11). */
  chaptersSyncedAt DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceAsset Asset?  @relation(fields: [sourceAssetId], references: [id])

  transcriptSegments TranscriptSegment[]
  scenes             VideoScene[]
  topicSegments      TopicSegment[]
  chapters           Chapter[]
  socialContent      SocialContent[]

  @@unique([projectId, youtubeVideoId])
  @@index([projectId])
  @@map("imported_videos")
}

// ── Chapters (Ai-video edit.md §5/§11, Phase 5) ────────────────────────────────
// YouTube-style chapters derived from the topic-segment analysis graph — one
// contiguous partition of the video. `source` distinguishes AI-detected rows
// from chapters imported from YouTube (Phase 6 sync); user edits are flagged so
// re-detection never overwrites a manual rename.

enum ChapterSource {
  DETECTED
  IMPORTED
}

// ── Social content factory (Ai-video edit.md §10, Phase 5) ────────────────────
// Text artifacts derived from the chapter/highlight graph in one batched call.
// `content` shape per kind: QUOTE_CARD {quote, attribution?, startMs};
// CAROUSEL {slides:[{heading, body}]}; BLOG_POST {markdown};
// NEWSLETTER {subject, markdown}.

enum SocialContentKind {
  QUOTE_CARD
  CAROUSEL
  BLOG_POST
  NEWSLETTER
}

// ── Wallet & Credit Ledger (billing spec §4/§5) ───────────────────────────────
// Ledger-first: the wallet row is a read cache; the append-only credit_ledger
// is the single source of truth and every balance is reconstructable from it.
// Credits are integers, never floats. All mutations go through WalletService.

model Wallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  balanceCredits     Int      @default(0)
  purchasedCredits   Int      @default(0)
  bonusCredits       Int      @default(0)
  promotionalCredits Int      @default(0)
  referralCredits    Int      @default(0)
  /** Phase 6 §5: trial credits are their own bucket, consumed before all others. */
  trialCredits       Int      @default(0)
  lifetimePurchased  Int      @default(0)
  lifetimeUsed       Int      @default(0)
  updatedAt          DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      CreditLedger[]
  reservations CreditReservation[]
  lots         CreditLot[]

  @@map("wallets")
}

// Credit lots (billing spec §5.4): every grant is a lot with its own expiry
// so "bonus expires first, purchased expires last" is enforceable. Debits
// consume lots in bucket-priority order, soonest-expiring first; the wallet
// bucket counters are caches over lot remainders.
model CreditLot {
  id        String    @id @default(cuid())
  walletId  String
  /** CreditBucket name: promotionalCredits | bonusCredits | referralCredits | purchasedCredits */
  bucket    String
  amount    Int
  remaining Int
  /** null = never expires (purchased credits). */
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, expiresAt])
  @@map("credit_lots")
}

enum LedgerEntryType {
  PURCHASE
  BONUS
  REFERRAL
  PROMO
  TRIAL
  USAGE_DEBIT
  REFUND
  EXPIRY
  ADJUSTMENT
}

enum LedgerReferenceType {
  PAYMENT
  AI_REQUEST
  COUPON
  REFERRAL
  ADMIN_ACTION
}

// Append-only: corrections are new ADJUSTMENT rows, never UPDATE/DELETE (§4.3).
model CreditLedger {
  id             String              @id @default(cuid())
  walletId       String
  entryType      LedgerEntryType
  /** Positive = credit, negative = debit. */
  amount         Int
  /** Wallet balance snapshot after this entry — audit anchor. */
  balanceAfter   Int
  referenceType  LedgerReferenceType
  referenceId    String?
  idempotencyKey String              @unique
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("credit_ledger")
}

// Reserve→settle soft holds (billing spec §5.3): a hold caps spendable
// balance without touching the ledger; settling posts the REAL debit and
// closes the hold. Expired HELD rows are ignored by availability math, so a
// crashed job can never strand credits.
enum ReservationStatus {
  HELD
  SETTLED
  RELEASED
}

model CreditReservation {
  id             String            @id @default(cuid())
  walletId       String
  amount         Int
  status         ReservationStatus @default(HELD)
  settledCredits Int?
  referenceType  String
  referenceId    String?
  idempotencyKey String            @unique
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, status, expiresAt])
  @@map("credit_reservations")
}

// ── AI provider registry & pricing (Phase 5 spec §4.1–4.4) ───────────────────
// The live health/failover state lives in the shared aiClient; these tables
// persist it for the admin surface + history, and hold the configurable cost
// and pricing rules the profit guard reads.

// ── Free trial & abuse prevention (Phase 6 spec §4–7) ─────────────────────────
// Trial credits are ordinary credit lots (bucket=trialCredits, consumed
// first); trial_grants is the one-per-verified-identity backstop; abuse
// signals extend the base fraud posture with fingerprint/IP scoring.

enum TrialStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  REVOKED
  PENDING_REVIEW
}

model TrialGrant {
  id                 String      @id @default(cuid())
  userId             String      @unique
  /** Hash of the verified identity (normalized email) — the hard one-trial backstop. */
  identityKey        String      @unique
  creditsGranted     Int
  status             TrialStatus @default(ACTIVE)
  verificationMethod String      @default("email")
  deviceFingerprint  String?
  ipHash             String?
  grantedAt          DateTime    @default(now())
  expiresAt          DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceFingerprint])
  @@map("trial_grants")
}

// Super-Admin-configurable trial tier (§7): one row per gated feature.
model TrialLimit {
  id         String   @id @default(cuid())
  feature    String   @unique
  access     String   @default("enabled") // enabled | limited | disabled
  limitValue Int?
  updatedAt  DateTime @updatedAt

  @@map("trial_limits")
}

enum AbuseDecision {
  ALLOW
  REVIEW
  BLOCK
}

model AbuseSignal {
  id                String        @id @default(cuid())
  userId            String
  deviceFingerprint String?
  ipHash            String?
  isVpn             Boolean       @default(false)
  duplicateDevice   Boolean       @default(false)
  duplicateIp       Boolean       @default(false)
  fraudScore        Float
  riskScore         Float
  decision          AbuseDecision
  reviewedBy        String?
  createdAt         DateTime      @default(now())

  @@index([userId, createdAt])
  @@map("abuse_signals")
}

// ── Growth engine Wave 2 (Phase 6 spec §4.4/4.5/4.9/4.10) ────────────────────

// Denormalized per-user usage profile — kept small for fast rule evaluation.
model UserBehaviour {
  id                  String    @id @default(cuid())
  userId              String    @unique
  chatsSent           Int       @default(0)
  videosAnalyzed      Int       @default(0)
  clipsGenerated      Int       @default(0)
  rendersRun          Int       @default(0)
  jobsTotal           Int       @default(0)
  lastActiveAt        DateTime?
  inactiveDays        Int       @default(0)
  trialCreditsUsedPct Float     @default(0)
  updatedAt           DateTime  @updatedAt

  @@map("user_behaviour")
}

model UpgradeRecommendation {
  id              String    @id @default(cuid())
  userId          String
  reasonCode      String
  recommendedPlan String
  confidence      Float
  dismissedAt     DateTime?
  converted       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("upgrade_recommendations")
}

enum OfferType {
  WELCOME
  FIRST_RECHARGE
  LOYALTY
  WINBACK
  UPGRADE
  LOW_CREDIT
}

enum OfferRewardType {
  BONUS_CREDITS
  FREE_PREMIUM_DAYS
}

model Offer {
  id               String          @id @default(cuid())
  type             OfferType
  name             String
  rewardType       OfferRewardType @default(BONUS_CREDITS)
  rewardValue      Int
  /** Minor units the recharge must reach to qualify (FIRST_RECHARGE). */
  minRechargeMinor Int?
  validFrom        DateTime        @default(now())
  validTo          DateTime?
  usageLimit       Int?
  perUserLimit     Int             @default(1)
  /** Qualification parameters per type, e.g. {"inactiveDaysMin":14} or {"maxBalance":50} (Phase 6 §10.1). */
  targetRule       Json?
  profitChecked    Boolean         @default(false)
  status           String          @default("active")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  redemptions OfferRedemption[]

  @@index([type, status])
  @@map("offers")
}

// Unique idempotency key = no duplicate bonus, ever (§12 revenue protection).
model OfferRedemption {
  id             String   @id @default(cuid())
  offerId        String
  userId         String
  paymentId      String?
  rewardGranted  Int
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("offer_redemptions")
}

// Credit marketplace (Phase 6 §12): packs define WHAT can be bought; the
// existing recharge/payment path does the buying. Regional pricing =
// multiple rows per region/currency.
model CreditPack {
  id         String   @id @default(cuid())
  name       String
  credits    Int
  priceMinor Int
  currency   String   @default("usd")
  region     String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, region])
  @@map("credit_packs")
}

enum AiProviderStatus {
  ACTIVE
  DEGRADED
  DISABLED
}

model AiProvider {
  id           String           @id @default(cuid())
  name         String           @unique
  status       AiProviderStatus @default(ACTIVE)
  priority     Int              @default(50)
  qualityScore Float            @default(0.8)
  failureRate  Float            @default(0)
  avgHealthScore Float          @default(100)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  healthEvents ProviderHealthEvent[]
  costRates    ProviderCostRate[]

  @@map("ai_providers")
}

model ProviderHealthEvent {
  id                  String   @id @default(cuid())
  providerId          String
  event               String
  score               Float
  consecutiveFailures Int      @default(0)
  checkedAt           DateTime @default(now())

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, checkedAt])
  @@map("provider_health_events")
}

// Versioned real-cost input to the profit guard (USD per 1M tokens).
model ProviderCostRate {
  id            String    @id @default(cuid())
  providerId    String
  model         String?
  inputCostPer1M  Float
  outputCostPer1M Float
  currency      String    @default("usd")
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, effectiveFrom])
  @@map("provider_cost_rates")
}

// What the USER is charged, in credits — most-specific rule wins
// (plan > model > provider > action default), quoted then locked at the
// wallet reservation (Phase 5 §7).
model PricingRule {
  id            String    @id @default(cuid())
  /** JobType name or 'chat' for copilot turns. */
  action        String
  model         String?
  provider      String?
  plan          String?
  creditCost    Int
  priority      Int       @default(0)
  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([action, isActive])
  @@map("pricing_rules")
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
  PAYPAL
  APPLE_IAP
  GOOGLE_PLAY_BILLING
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

model Payment {
  id               String         @id @default(cuid())
  userId           String
  gateway          PaymentGateway
  gatewayPaymentId String?        @unique
  /** Minor units (cents/paise) — never floats (§4). */
  amount           Int
  currency         String         @default("usd")
  status           PaymentStatus  @default(PENDING)
  creditsGranted   Int            @default(0)
  idempotencyKey   String         @unique
  failureReason    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("payments")
}

// Gateway webhook idempotency (§6.2): duplicate deliveries are no-ops.
model WebhookEvent {
  id          String    @id @default(cuid())
  gateway     PaymentGateway
  eventId     String
  eventType   String
  status      String    @default("processed")
  processedAt DateTime  @default(now())

  @@unique([gateway, eventId])
  @@map("webhook_events")
}

model SocialContent {
  id              String            @id @default(cuid())
  importedVideoId String
  kind            SocialContentKind
  title           String
  content         Json
  createdAt       DateTime          @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)

  @@index([importedVideoId, kind])
  @@map("social_content")
}

model Chapter {
  id              String        @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  title           String
  summary         String        @db.Text
  keyPoints       String[]      @default([])
  confidence      Float
  source          ChapterSource @default(DETECTED)
  editedByUser    Boolean       @default(false)
  // Church AI pack (Ai-video edit.md §11) — filled by CHURCH_PACK_GENERATION,
  // empty until the pack is requested. devotional set == chapter processed.
  bibleRefs           String[] @default([])
  discussionQuestions String[] @default([])
  devotional          String?  @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)
  clips         ShortClip[]

  @@index([importedVideoId, startMs])
  @@map("chapters")
}

enum TranscriptStatus {
  PENDING
  YOUTUBE_CAPTIONS
  ASR_GENERATED
  FAILED
}

model TranscriptSegment {
  id              String   @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  speakerId       String?
  text            String   @db.Text
  embedding       Float[]  @default([])
  createdAt       DateTime @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)

  @@index([importedVideoId, startMs])
  @@map("transcript_segments")
}

model VideoScene {
  id                    String   @id @default(cuid())
  importedVideoId       String
  startMs               Int
  endMs                 Int
  speakerId             String?
  emotionScores         Json?
  sceneChangeConfidence Float?
  createdAt             DateTime @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)

  @@index([importedVideoId, startMs])
  @@map("video_scenes")
}

model TopicSegment {
  id              String        @id @default(cuid())
  importedVideoId String
  startMs         Int
  endMs           Int
  category        TopicCategory
  title           String
  summary         String        @db.Text
  confidence      Float
  createdAt       DateTime      @default(now())

  importedVideo ImportedVideo @relation(fields: [importedVideoId], references: [id], onDelete: Cascade)
  highlight     Highlight?
  clips         ShortClip[]

  @@index([importedVideoId, startMs])
  @@map("topic_segments")
}

enum TopicCategory {
  QUESTION_ANSWERED
  STORY
  TUTORIAL_STEP
  FUNNY_MOMENT
  IMPORTANT_STATEMENT
  HOOK
  PROBLEM
  SOLUTION
  STATISTIC
  TIP
  MISTAKE
  WARNING
  QUOTE
  OPINION
  LESSON
  SUCCESS_STORY
  FAILURE
  CALL_TO_ACTION
}

model Highlight {
  id               String   @id @default(cuid())
  topicSegmentId   String   @unique
  virality         Float
  emotion          Float
  retention        Float
  hookStrength     Float
  education        Float
  entertainment    Float
  confidence       Float
  trendPotential   Float
  shortSuitability Float
  finalScore       Float
  reason           String   @db.Text
  titleSuggestion  String
  keywords         String[] @default([])
  createdAt        DateTime @default(now())

  topicSegment TopicSegment @relation(fields: [topicSegmentId], references: [id], onDelete: Cascade)

  @@index([finalScore])
  @@map("highlights")
}

model ShortClip {
  id               String          @id @default(cuid())
  // Provenance: exactly one of topicSegmentId (highlight-based Shorts) or
  // chapterId (chapter-based Small Videos, Ai-video edit.md §10) is set.
  topicSegmentId   String?
  chapterId        String?
  projectId        String
  clipType         ClipType
  status           ShortClipStatus @default(CANDIDATE)
  sourceStartMs    Int
  sourceEndMs      Int
  reframeKeyframes Json?
  renderAssetId    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  topicSegment TopicSegment? @relation(fields: [topicSegmentId], references: [id], onDelete: Cascade)
  chapter      Chapter?      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renderAsset  Asset?        @relation(fields: [renderAssetId], references: [id])

  timeline   ShortsTimeline?
  thumbnails ShortsThumbnail[]
  renderJobs ShortsRenderJob[]
  exports    ShortsExportHistory[]

  @@index([projectId, status])
  @@map("short_clips")
}

enum ClipType {
  YOUTUBE_SHORTS
  INSTAGRAM_REELS
  TIKTOK
  LINKEDIN_CLIPS
  FACEBOOK_REELS
  PODCAST_HIGHLIGHTS
  // Horizontal 1–10 min chapter videos (Ai-video edit.md §10, Phase 5)
  SMALL_VIDEO
}

enum ShortClipStatus {
  CANDIDATE
  IN_EDITING
  READY_FOR_RENDER
  RENDERING
  RENDERED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPORTED
  PUBLISHED
}

model ShortsTimeline {
  id          String   @id @default(cuid())
  shortClipId String   @unique
  durationMs  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shortClip   ShortClip             @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  tracks      ShortsTimelineTrack[]
  captions    ShortsCaption[]
  editHistory ShortsTimelineEdit[]

  @@map("shorts_timelines")
}

model ShortsTimelineTrack {
  id         String          @id @default(cuid())
  timelineId String
  type       ShortsTrackType
  orderIndex Int

  timeline ShortsTimeline       @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  items    ShortsTimelineItem[]

  @@index([timelineId, orderIndex])
  @@map("shorts_timeline_tracks")
}

enum ShortsTrackType {
  VIDEO
  AUDIO
  MUSIC
  CAPTION
  OVERLAY
}

model ShortsTimelineItem {
  id            String  @id @default(cuid())
  trackId       String
  startMs       Int
  endMs         Int
  sourceAssetId String?
  cropRect      Json?
  rotationDeg   Float?  @default(0)
  speed         Float?  @default(1.0)
  volume        Float?  @default(1.0)
  properties    Json?

  track       ShortsTimelineTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  sourceAsset Asset?              @relation(fields: [sourceAssetId], references: [id])

  @@index([trackId, startMs])
  @@map("shorts_timeline_items")
}

model ShortsCaption {
  id           String  @id @default(cuid())
  timelineId   String
  startMs      Int
  endMs        Int
  text         String
  speakerColor String?
  emphasis     Boolean @default(false)
  emoji        String?
  templateId   String?

  timeline ShortsTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId, startMs])
  @@map("shorts_captions")
}

model ShortsTimelineEdit {
  id         String   @id @default(cuid())
  timelineId String
  actorId    String // User.id, or 'AI_ASSISTANT'
  command    Json
  createdAt  DateTime @default(now())

  timeline ShortsTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId, createdAt])
  @@map("shorts_timeline_edits")
}

model ShortsThumbnail {
  id          String   @id @default(cuid())
  shortClipId String
  assetId     String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  shortClip ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([shortClipId])
  @@map("shorts_thumbnails")
}

model ShortsRenderJob {
  id             String            @id @default(cuid())
  shortClipId    String
  jobId          String // AgentJob.id
  ffmpegPass     Int               @default(0)
  checkpointData Json?
  status         ShortsRenderStatus @default(QUEUED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  shortClip ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)

  @@index([shortClipId])
  @@map("shorts_render_jobs")
}

enum ShortsRenderStatus {
  QUEUED
  RUNNING
  CHECKPOINTED
  COMPLETE
  FAILED
}

model ShortsExportHistory {
  id              String    @id @default(cuid())
  shortClipId     String
  clipType        ClipType
  exportAssetId   String
  publishedAt     DateTime?
  publishTargetId String?
  createdAt       DateTime  @default(now())

  shortClip   ShortClip @relation(fields: [shortClipId], references: [id], onDelete: Cascade)
  exportAsset Asset     @relation(fields: [exportAssetId], references: [id])

  @@index([shortClipId])
  @@map("shorts_export_history")
}


// ── Unified Intent/Action Layer (Ai-video edit.md §8, §14) ─────────────────────
// One audit trail for every action regardless of input modality (UI click,
// Copilot chat, voice command) — the doc's single-execution-path principle.

enum ActionSource {
  UI
  COPILOT
  VOICE
}

enum ActionStatus {
  EXECUTED
  NEEDS_CONFIRMATION
  FAILED
}

model ActionRecord {
  id            String       @id @default(cuid())
  userId        String
  projectId     String?
  source        ActionSource
  intentType    String
  intentPayload Json         @default("{}")
  status        ActionStatus
  fromCache     Boolean      @default(false)
  tokensUsed    Int          @default(0)
  error         String?
  createdAt     DateTime     @default(now())

  tokenUsage TokenUsage[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("actions")
}

// Compressed conversation memory — intent history + short summary, never raw
// transcripts (token rule §12.2.6). One row per user for now.
model CopilotSessionMemory {
  id            String   @id @default(cuid())
  userId        String   @unique
  summary       String   @default("")
  lastIntentIds String[] @default([])
  updatedAt     DateTime @updatedAt

  @@map("copilot_sessions")
}

// Spoken-command history — powers the transcript chips and future undo (§14).
model VoiceCommand {
  id             String   @id @default(cuid())
  userId         String
  projectId      String?
  rawTranscript  String
  resolvedIntent Json?
  executed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@map("voice_commands")
}

// Token usage ledger — feeds the Analytics AI-usage dashboard (§12.2.8).
// Attribution columns are loose strings (no FKs) so cost history survives
// video/job deletion; they're filled from the AsyncLocalStorage AI context.
model TokenUsage {
  id              String   @id @default(cuid())
  userId          String?
  actionId        String?
  jobId           String?
  projectId       String?
  importedVideoId String?
  provider        String
  model           String
  tokensIn        Int      @default(0)
  tokensOut       Int      @default(0)
  costUsd         Float    @default(0)
  fromCache       Boolean  @default(false)
  createdAt       DateTime @default(now())

  action ActionRecord? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([importedVideoId, createdAt])
  @@map("token_usage")
}

// ── Auth Sessions & OAuth ─────────────────────────────────────────────────────

model AccountLink {
  id              String   @id @default(cuid())
  userId          String
  provider        String
  providerSubject String
  email           String?
  linkedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("account_links")
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  familyId         String
  refreshTokenHash String    @unique
  device           String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  rotatedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("auth_sessions")
}

model OAuthState {
  id           String    @id @default(cuid())
  provider     String
  state        String    @unique
  codeVerifier String
  nonce        String
  redirectUri  String
  linkUserId   String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  usedAt       DateTime?

  @@map("oauth_states")
}
