# ── App ─────────────────────────────────────────────
NODE_ENV=development
API_PORT=4007
WEB_PORT=3007
API_URL=http://localhost:4007
WEB_URL=http://localhost:3007
NEXT_PUBLIC_API_URL=http://localhost:4007/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4007

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://cf:cf@localhost:5434/creatorforce

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Auth ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=change-me-in-production-min-32-chars

# ── JWT (worker service auth) ─────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=900

# ── YouTube / Google OAuth ────────────────────────────
# Setup checklist (https://console.cloud.google.com/):
#   1. Create a project → APIs & Services → Enable "YouTube Data API v3"
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
#   3. Authorised redirect URIs: http://localhost:4007/api/v1/channels/oauth/callback
#   4. OAuth consent screen: add scopes openid, email, profile, youtube.readonly, youtube.upload
#   5. If app is in "Testing" mode, add your Google account as a test user
#   6. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
YOUTUBE_API_KEY=

# ── Social Sign-In: Google ─────────────────────────────
# Optional override — falls back to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above if unset.
# Use these when you want a separate OAuth client for social sign-in vs YouTube channel connection.
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ── Social Sign-In: Apple ──────────────────────────────
# Setup: https://developer.apple.com/account/resources/identifiers/list/serviceId
#   1. Create an App ID with "Sign in with Apple" capability.
#   2. Create a Services ID (this is APPLE_CLIENT_ID), enable Sign in with Apple.
#   3. Register your redirect URI (e.g. https://yourdomain.com/auth/apple/return).
#   4. Create a Key with Sign in with Apple enabled; download the .p8 file.
#   5. Note the Team ID, Key ID, and paste the .p8 file contents below (replace newlines with \n).
APPLE_CLIENT_ID=com.yourapp.service
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# PEM private key (.p8 contents). Newlines may be stored as literal \n sequences.
APPLE_PRIVATE_KEY=

# ── Social Sign-In: Facebook ───────────────────────────
# Setup: https://developers.facebook.com/apps/
#   1. Create an app → Add "Facebook Login" product.
#   2. Set Valid OAuth Redirect URIs to your callback URL.
#   3. Copy App ID and App Secret below.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Shorts Studio ─────────────────────────────────────
# Path to the yt-dlp binary used to fetch the creator's own source videos for
# the Shorts import pipeline. Leave empty if yt-dlp is on PATH.
YT_DLP_PATH=

# ── OAuth Token Encryption ─────────────────────────────
# REQUIRED — the API refuses to boot without it. Must be exactly 64 hex
# characters (32 bytes) and unique per environment. Left blank on purpose so a
# copy-paste of this file can never ship a predictable key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── AI Providers ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# ── Cloudflare R2 ─────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=creatorforce-assets
R2_PUBLIC_URL=

# ── Sentry ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── n8n ───────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5679
N8N_API_KEY=

# Dev-only: allow clearly-labelled offline placeholder media (silent-ish synth voice,
# chord-pad music, gradient images) when no real provider key is configured.
# Default OFF: stages FAIL rather than fabricate output (see docs/audit-placeholders.md).
ALLOW_OFFLINE_MEDIA=false

# RBAC role elevation (billing spec §9.2) — comma-separated, case-insensitive
SUPER_ADMIN_EMAILS=
OWNER_EMAILS=

# Wallet credit conversion (billing spec §5.2): credits granted per 1 USD
CREDITS_PER_USD=100

# Reserve→settle credit holds (billing spec §5.3) — off by default so
# zero-credit local deployments keep working; flip on to enforce
BILLING_ENFORCE_CREDITS=false
AI_CREDIT_MARKUP=2
JOB_RESERVE_CREDITS=50
COPILOT_RESERVE_CREDITS=5
HOLD_TTL_MINUTES=120

# Credit lot expiry (billing spec §5.4) — days until each bucket expires; purchased never expires
CREDIT_TTL_PROMO_DAYS=30
CREDIT_TTL_BONUS_DAYS=90
CREDIT_TTL_REFERRAL_DAYS=180

# Profit protection (Phase 5 spec §8): minimum margin for any priced action/offer
MIN_PROFIT_MARGIN=0.3

# Free trial (Phase 6 spec §5) — credits granted on verified signup; 0 disables trials
TRIAL_CREDITS=100
TRIAL_EXPIRY_DAYS=15

# Direct-grant offer cap (Phase 6 §10.1) — free credits an offer may grant without a recharge
MAX_FREE_GRANT_CREDITS=100

# ── Observability ──────────────────────────────────────
# Optional static token that protects GET /metrics from public scraping.
# When set, Prometheus (and any scraper) must send: Authorization: Bearer <value>
# Leave empty in local dev to allow open access.
# METRICS_TOKEN=

# Grafana admin password for the monitoring docker-compose stack (infra/monitoring/).
# GRAFANA_ADMIN_PASSWORD=admin

# ── Backups & Disaster Recovery ────────────────────────────────────────────────
# Directory where pg_dump files are written by infra/dr/backup.sh (and backup.ps1).
# Defaults to ./backups (relative to the script's working directory) if unset.
# BACKUP_DIR=/var/backups/creatorforce

# Number of days to retain local dump files before backup.sh prunes them.
# Default: 14. Set lower in space-constrained environments.
# BACKUP_RETENTION_DAYS=14

# Optional rclone remote destination for off-site upload (S3, R2, GCS, etc.).
# Leave unset to skip remote upload and keep backups local only.
# See infra/dr/backup.sh for setup notes.
# RCLONE_REMOTE=s3:my-bucket/creatorforce-db

# AI cost spike alert threshold in USD (used in infra/monitoring/alerts.yml comment).
# Tune the threshold in alerts.yml directly; this env var documents the intended value.
# AI_COST_SPIKE_THRESHOLD_USD=10
